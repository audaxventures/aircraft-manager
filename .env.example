# Postgres connection string (Vercel Postgres or Neon in production, local Postgres in dev)
DATABASE_URL="postgresql://user:password@localhost:5432/aircraft_manager?schema=public"

# Auth (single-user login)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
# The email you'll sign in with
ADMIN_EMAIL=""
# bcrypt hash of your chosen passphrase — generate with:
# node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" "your-passphrase-here"
# NOTE: in a local .env file, escape every "$" as "\$" (Next.js expands $VAR
# references in .env files, which otherwise corrupts the hash). On Vercel's
# environment variable UI, paste the hash unescaped — no expansion happens there.
ADMIN_PASSWORD_HASH=""

# Vercel Blob (receipt attachments) — create a Blob store in the Vercel dashboard
# and copy its token here (Vercel injects this automatically when linked to a project).
BLOB_READ_WRITE_TOKEN=""

// Prisma schema for the C-FPFX Aircraft Manager
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A single aircraft record today, but modeled as a table (not hardcoded)
// so a second tail number could be added later without a schema rebuild.
model Aircraft {
  id                String   @id @default(cuid())
  tailNumber        String   @unique
  type              String
  baseAirport       String
  fiscalYearStartMonth Int   @default(1) // 1-12
  // Reference facts used on the Weekly Status Report letterhead and to
  // compute lifetime totals (this app only knows hours/cycles logged since
  // trips started being tracked here, so purchase totals anchor the running count).
  serialNumber      String?
  ownerOperator     String?
  programManager    String?
  purchaseTotalHours  Decimal @default(0) @db.Decimal(8, 1)
  purchaseTotalCycles Int     @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum CostType {
  FIXED
  DIRECT
}

enum Currency {
  CAD
  USD
}

model CostCategory {
  id         String     @id @default(cuid())
  name       String     @unique
  type       CostType
  sortOrder  Int        @default(0)
  archived   Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  entries    CostEntry[]
}

model Vendor {
  id        String      @id @default(cuid())
  name      String      @unique
  archived  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  entries   CostEntry[]
}

model CostEntry {
  id            String       @id @default(cuid())
  date          DateTime
  categoryId    String
  category      CostCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  vendorId      String?
  vendor        Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  invoiceNumber String?
  amount        Decimal      @db.Decimal(12, 2)
  currency      Currency     @default(CAD)
  notes         String?
  attachments   Attachment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([vendorId])
}

model Pilot {
  id            String          @id @default(cuid())
  name          String          @unique
  archived      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  trips         Trip[]          @relation("TripPilotInCommand")
  secondPilotTrips Trip[]       @relation("TripSecondInCommand")
  dutyDayLogs   DutyDayLog[]
  calendarEvents CalendarEvent[]
}

model Passenger {
  id        String          @id @default(cuid())
  name      String          @unique
  createdAt DateTime        @default(now())
  trips     TripPassenger[]
}

enum TripStatus {
  PLANNED
  COMPLETED
}

model Trip {
  id                String          @id @default(cuid())
  status            TripStatus      @default(COMPLETED)
  date              DateTime
  endDate           DateTime?
  departureAirport  String
  arrivalAirport    String
  routeLabel        String?
  hours             Decimal         @default(0) @db.Decimal(6, 2)
  cycles            Int             @default(0)
  miles             Int             @default(0)
  purpose           String?
  notes             String?
  pilotId           String?
  pilot             Pilot?          @relation("TripPilotInCommand", fields: [pilotId], references: [id], onDelete: SetNull)
  secondPilotId     String?
  secondPilot       Pilot?          @relation("TripSecondInCommand", fields: [secondPilotId], references: [id], onDelete: SetNull)
  // UTC decimal-hour time of day (e.g. 14.3 = 14:18), rounded up to the nearest 6 minutes.
  takeoffTime       Decimal?        @db.Decimal(4, 1)
  landingTime       Decimal?        @db.Decimal(4, 1)
  dayTakeoffs       Int             @default(0)
  dayLandings       Int             @default(0)
  nightTakeoffs     Int             @default(0)
  nightLandings     Int             @default(0)
  passengers        TripPassenger[]
  attachments       Attachment[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([date])
  @@index([pilotId])
  @@index([secondPilotId])
  @@index([status])
}

model TripPassenger {
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  passengerId String
  passenger   Passenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

  @@id([tripId, passengerId])
  @@index([passengerId])
}

model DutyDayLog {
  id                      String   @id @default(cuid())
  pilotId                 String
  pilot                   Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  date                    DateTime
  reportTime              DateTime
  dutyEndTime             DateTime
  restPeriodBeforeHours   Decimal  @db.Decimal(6, 2)
  splitDutyApplied        Boolean  @default(false)
  splitDutyNote           String?
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([pilotId, date])
  @@unique([pilotId, date])
}

model Attachment {
  id          String     @id @default(cuid())
  filename    String
  url         String
  size        Int
  mimeType    String
  costEntryId String?
  costEntry   CostEntry? @relation(fields: [costEntryId], references: [id], onDelete: Cascade)
  tripId      String?
  trip        Trip?      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
}

// Configurable categories for the Scheduling calendar (Maintenance, Pilot
// Time Away, etc). Trips are not stored here — they live in Trip and are
// merged into the calendar view live, so there's one source of truth.
model EventCategory {
  id        String          @id @default(cuid())
  name      String          @unique
  color     String          @default("#2a78d6")
  sortOrder Int             @default(0)
  archived  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  events    CalendarEvent[]
}

model CalendarEvent {
  id         String        @id @default(cuid())
  categoryId String
  category   EventCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  title      String
  startDate  DateTime
  endDate    DateTime
  pilotId    String?
  pilot      Pilot?        @relation(fields: [pilotId], references: [id], onDelete: SetNull)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([startDate])
  @@index([categoryId])
}

// Saved column selections for the Trips export (e.g. a "Client report" preset
// vs a full internal export), so the picker doesn't need to be rebuilt each time.
model TripExportPreset {
  id        String   @id @default(cuid())
  name      String   @unique
  columns   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A saved weekly client status report. The narrative and list sections are
// free-form and user-edited; auto-computed stats (totals, YTD, next trip)
// are folded into weekOverview as an editable starting draft rather than
// being re-derived at read time, so a saved report's wording never shifts
// under the user after the fact.
model WeeklyReport {
  id                String   @id @default(cuid())
  reportDate        DateTime
  ownerOperator     String?
  programManager    String?
  weekOverview      String
  accomplishments   String[]
  newIssues         String[]
  toBeCompleted     String[]
  customerDecisions String[]
  // [{ description: string, due: string }]
  maintenanceItems  Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([reportDate])
}

// Singleton row holding the configurable CARS 604 / CAR 401.05(2) thresholds,
// so regulatory figures aren't hardcoded and can be updated if rules change.
model RegulatorySettings {
  id                            String   @id @default(cuid())
  // CARS 604 duty day limits
  maxFlightDutyHours            Decimal  @default(14) @db.Decimal(4, 2)
  extendedMaxFlightDutyHours    Decimal  @default(15) @db.Decimal(4, 2)
  rolling30DayFlightHoursLimit  Decimal  @default(70) @db.Decimal(5, 2)
  extensionRestPeriodHours      Decimal  @default(24) @db.Decimal(4, 2)
  minRestPeriodHours            Decimal  @default(36) @db.Decimal(4, 2)
  restPeriodWindowDays          Int      @default(7)
  splitDutyMaxExtensionHours    Decimal  @default(4) @db.Decimal(4, 2)
  splitDutyMinRestHours         Decimal  @default(4) @db.Decimal(4, 2)
  // CAR 401.05(2) recency
  currencyTakeoffsRequired      Int      @default(5)
  currencyLandingsRequired      Int      @default(5)
  currencyPeriodMonths          Int      @default(6)
  // Company/regulatory caps on rolling flight time per pilot, shown on the
  // Duty Days pilot cards (distinct from rolling30DayFlightHoursLimit above,
  // which only governs CARS 604 duty-day extension eligibility).
  flightHours30DayLimit         Decimal  @default(120) @db.Decimal(6, 2)
  flightHours90DayLimit         Decimal  @default(300) @db.Decimal(6, 2)
  flightHours12MonthLimit       Decimal  @default(1200) @db.Decimal(6, 2)
  updatedAt                     DateTime @updatedAt
}
